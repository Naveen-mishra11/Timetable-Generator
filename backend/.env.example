# Server Configuration
PORT=5000

# Database Configuration
# For local MongoDB:
# MONGO_URI=mongodb://localhost:27017/timetable_generator
#
# For MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/timetable_generator?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/timetable_generator

# JWT Secret Key
# Generate a strong random string for production (at least 32 characters)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here